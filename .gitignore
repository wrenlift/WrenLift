/target
profile.json.gz
/hatch/
.DS_Store
# `wasm-pack build wasm --target web` output. Regenerated from
# `wasm/src/lib.rs` + the runtime source on every build; we
# track the recipe, not the bytes.
wasm/pkg/

# Pages build artefacts. The bench workflow regenerates these
# into `site/` on every deploy (results.json from the bench
# run, the wasm playground staged from `wasm-pack build`).
# Tracking them would bloat the tree with output that's
# rebuilt every commit.
site/benchmark/results.json
site/playground/
site/install.sh

# Local-only state from /loop's wakeup scheduler — never tracked.
.claude/
